# Recall.ai API ключ (обязательно)
RECALL_API_KEY=your_recall_api_key_here

# Имя бота в Zoom встрече
BOT_NAME=Nechto Zoom Analytics

# Публичный URL сервера (Railway даёт автоматически)
# Без этой переменной чат-ответы бота отключены
WEBHOOK_BASE_URL=https://your-app.up.railway.app

# Порт (Railway задаёт автоматически, не трогай)
# PORT=8000

# Путь к SQLite базе (для Railway Volume: /data/analytics.db)
# DB_PATH=analytics.db

# Папка для файлов материалов (для Railway Volume: /data/materials_files)
# MATERIALS_DIR=materials_files
